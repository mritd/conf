" Plug 插件管理
call plug#begin('~/.vim/plugged')
Plug 'vim-airline/vim-airline'          " 状态栏美化
Plug 'terryma/vim-multiple-cursors'     " 多光标编辑 (Ctrl+N)
Plug 'sheerun/vim-polyglot'             " 多语言语法高亮包
Plug 'joshdick/onedark.vim'             " OneDark 配色方案
Plug 'ojroques/vim-oscyank', {'branch': 'main'}            " OSC52 远程剪贴板复制
Plug 'scrooloose/nerdtree', {'on': 'NERDTreeToggle'}       " 文件树浏览器 (按需加载)
call plug#end()
